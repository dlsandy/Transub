{
  "name": "transub",
  "version": "1.3.0",
  "description": "Windows 桌面字幕工具：基于 TransWithAI 的批量转写/翻译，以及 SRT/VTT/LRC 结构化字幕编辑与视频同步预览",
  "main": "electron/main.js",
  "author": "Transub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlsandy/Transub.git"
  },
  "bugs": {
    "url": "https://github.com/dlsandy/Transub/issues"
  },
  "homepage": "https://github.com/dlsandy/Transub#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node tools/setup-electron.js && node tools/setup-vendor-assets.js && node tools/build-css.js",
    "start": "electron .",
    "start:editor": "electron . --subtitle-editor-only",
    "build:css": "node tools/build-css.js",
    "build:renderer": "node tools/build-renderer.js",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "build": "powershell -ExecutionPolicy Bypass -File tools/build.ps1",
    "build:dir": "powershell -ExecutionPolicy Bypass -File tools/build.ps1 -Target dir",
    "build:portable": "powershell -ExecutionPolicy Bypass -File tools/build.ps1 -Target portable",
    "build:setup": "powershell -ExecutionPolicy Bypass -File tools/build.ps1 -Target nsis",
    "test": "node tests/transwithai-parsers.test.js && node tests/subtitle-format.test.js && node tests/media-protocol.test.js && node tests/subtitle-split.test.js && node tests/subtitle-fluency.test.js && node tests/subtitle-qc.test.js && node tests/subtitle-meta.test.js && node tests/subtitle-glossary.test.js && node tests/ffmpeg-silence.test.js",
    "icons": "node tools/generate-icons.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.5",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17"
  },
  "build": {
    "appId": "com.transub.app",
    "productName": "Transub",
    "copyright": "Copyright © 2026 Transub",
    "directories": {
      "output": "dist",
      "buildResources": "electron"
    },
    "icon": "app.ico",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "renderer-dist",
        "to": ".",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "_internal",
        "to": "_internal",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "afterPack": "tools/after-pack.js",
    "extraMetadata": {
      "description": "Transub 字幕工具"
    },
    "win": {
      "icon": "app.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Transub",
      "installerIcon": "app.ico",
      "uninstallerIcon": "app.ico",
      "installerHeaderIcon": "app.ico"
    },
    "portable": {
      "artifactName": "Transub-${version}-portable.exe"
    }
  }
}
