{
  "name": "transub",
  "version": "2.0.0",
  "description": "Windows 桌面字幕工具：基于 TransWithAI 的批量转写/翻译，以及 SRT/VTT/LRC 结构化字幕编辑与视频同步预览",
  "main": "electron/main.js",
  "author": "Transub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlsandy/Transub.git"
  },
  "bugs": {
    "url": "https://github.com/dlsandy/Transub/issues"
  },
  "homepage": "https://github.com/dlsandy/Transub#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "postinstall": "node tools/setup-electron.js && node tools/setup-vendor-assets.js && node tools/build-css.js",
    "setup:ffmpeg": "node tools/setup-ffmpeg.js",
    "start": "node tools/patch-electron-icon.js && electron .",
    "start:editor": "node tools/patch-electron-icon.js && electron . --subtitle-editor-only",
    "build:css": "node tools/build-css.js",
    "build:renderer": "node tools/build-renderer.js",
    "verify:packaging": "node tools/verify-packaging.js",
    "pack": "npm run build:renderer && npm run verify:packaging && electron-builder --dir",
    "dist": "npm run build:renderer && npm run verify:packaging && electron-builder",
    "build": "powershell -ExecutionPolicy Bypass -File tools/build.ps1",
    "build:dir": "powershell -ExecutionPolicy Bypass -File tools/build.ps1 -Target dir",
    "build:zip": "powershell -ExecutionPolicy Bypass -File tools/build.ps1 -Target zip",
    "build:setup": "powershell -ExecutionPolicy Bypass -File tools/build.ps1 -Target nsis",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint electron src/js tests tools --max-warnings 200",
    "lint:fix": "eslint electron src/js tests tools --fix",
    "format": "prettier --write \"electron/**/*.js\" \"src/js/**/*.js\" \"tests/**/*.js\" \"tools/**/*.js\"",
    "format:check": "prettier --check \"electron/**/*.js\" \"src/js/**/*.js\" \"tests/**/*.js\" \"tools/**/*.js\"",
    "icons": "node tools/generate-icons.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.5",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.5.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.transub.app",
    "productName": "Transub",
    "copyright": "Copyright © 2026 Transub",
    "directories": {
      "output": "dist",
      "buildResources": "electron"
    },
    "icon": "app.ico",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "renderer-dist/**/*",
      "src/js/*-core.js",
      "src/js/subtitle-chinese-dict.js"
    ],
    "asarUnpack": [
      "electron/app.ico",
      "electron/editor-app.ico",
      "electron/tray-icon-subtitle*.png",
      "electron/icon-256.png",
      "electron/editor-icon-256.png"
    ],
    "extraResources": [
      {
        "from": "electron/app.ico",
        "to": "icons/app.ico"
      },
      {
        "from": "electron/editor-app.ico",
        "to": "icons/editor-app.ico"
      }
    ],
    "extraFiles": [
      {
        "from": "_internal",
        "to": "_internal",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "disableAsarIntegrity": true,
    "afterPack": "tools/after-pack.js",
    "extraMetadata": {
      "description": "Transub 字幕工具"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dlsandy",
        "repo": "Transub"
      }
    ],
    "win": {
      "icon": "app.ico",
      "signExecutable": false,
      "signAndEditExecutable": true,
      "forceCodeSigning": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "packElevateHelper": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Transub",
      "include": "installer.nsh",
      "installerIcon": "app.ico",
      "uninstallerIcon": "app.ico",
      "installerHeaderIcon": "app.ico",
      "artifactName": "Transub-Setup-${version}.${ext}"
    }
  }
}
